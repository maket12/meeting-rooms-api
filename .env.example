# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=meeting-rooms-user
DB_PASSWORD=meeting-rooms-password
DB_NAME=meeting-rooms-db
DB_SSL_MODE=prefer

DB_MAX_CONNECTIONS=30
DB_MIN_CONNECTIONS=10
DB_MAX_CONNECTION_LIFETIME=10m
DB_MAX_CONNECTION_IDLETIME=5m

# --- AUTH CONSTANTS ---
AUTH_SECRET=super-secret-token
AUTH_TTL=1h
DUMMY_ADMIN_ID=00000000-0000-0000-0000-000000000001
DUMMY_USER_ID=00000000-0000-0000-0000-000000000002

# --- PASSWORD HASHER ---
PASSWORD_COST=10

# --- SERVER ---
HTTP_PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=production


# --- TEST CONFIGURATION ---
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=test-user
TEST_DB_PASSWORD=test-pass
TEST_DB_NAME=test-db
TEST_DB_SSL_MODE=disable

TEST_DB_MAX_CONNECTIONS=30
TEST_DB_MIN_CONNECTIONS=30
TEST_DB_MAX_CONNECTION_LIFETIME=10m
TEST_DB_MAX_CONNECTION_IDLETIME=5m